{
  "name": "turboclean",
  "version": "1.0.0",
  "description": "Recursively deletes .next and node_modules directories to free up disk space",
  "type": "module",
  "bin": {
    "turboclean": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "next",
    "clean",
    "nextjs",
    "node_modules"
  ],
  "license": "MIT"
}
